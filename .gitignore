# Xcode
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/
Signing.xcconfig
DerivedData/
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# macOS
.DS_Store
*.swp
*~

# ONNX models (too large for git — use Git LFS or download script)
*.onnx
# CoreML packages (generated via convert/)
*.mlpackage
*.pyc

# HuggingFace download artifacts in boxer/
boxer/.gitattributes
boxer/.gitattributes.*
boxer/README.md
boxer/README.md.*
boxer/*.onnx.lock
boxer/*.onnx.metadata

# Obsidian — per-user editor state (shared config like graph.json stays tracked)
wiki/.obsidian/workspace.json
wiki/.obsidian/workspace-mobile.json
wiki/.obsidian/cache

# Old / backup model snapshots — kept locally for rollback, never committed
# and never inside boxer/ (Xcode 16's PBXFileSystemSynchronizedRootGroup
# would auto-include them and cause duplicate-class compile errors).
archive/
